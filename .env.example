# Google Calendar OAuth 2.0 (create at console.cloud.google.com)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Jira Cloud
JIRA_DOMAIN=yourcompany.atlassian.net
JIRA_EMAIL=user@example.com
JIRA_API_TOKEN=

# AI Providers (configure one or more for stress scoring)
# Priority order: first available provider is used, failover to next
GROQ_API_KEYS=key1,key2
GEMINI_API_KEYS=
OPENAI_API_KEYS=
ANTHROPIC_API_KEYS=

# AI scoring config
AI_PROVIDER_PRIORITY=groq,gemini,openai,anthropic
AI_RECALC_HOURS=6
