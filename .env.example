# ─── Google Calendar OAuth 2.0 ───────────────────────────────
# Create at: https://console.cloud.google.com/apis/credentials
# Type: Desktop app | Redirect URI: http://localhost:34567/oauth/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Jira Cloud ──────────────────────────────────────────────
# Multiple domains: comma-separated (same credentials for all)
# API token: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_DOMAINS=company1.atlassian.net,company2.atlassian.net
JIRA_EMAIL=
JIRA_API_TOKEN=

# ─── AI Providers (optional — enables cognitive load scoring) ─
# Configure one or more. First available is used, failover to next.
# Multiple keys per provider: comma-separated (rotation on rate limit)
GROQ_API_KEYS=
GEMINI_API_KEYS=
OPENAI_API_KEYS=
ANTHROPIC_API_KEYS=

# Provider priority order
AI_PROVIDER_PRIORITY=groq,gemini,openai,anthropic
AI_RECALC_HOURS=6
