{
  "name": "deadlineaura",
  "version": "1.4.0",
  "description": "Desktop widget that creates ambient visual pressure based on upcoming deadlines",
  "main": "main.js",
  "scripts": {
    "start": "electron-rebuild && electron .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "sync": "node core/sync-daemon.js",
    "rebuild": "electron-rebuild",
    "dist": "electron-builder --linux deb --publish never",
    "prepare": "husky"
  },
  "engines": {
    "node": ">=20.0.0 <24.0.0"
  },
  "private": true,
  "license": "Apache-2.0",
  "author": "Andrea Bonn",
  "repository": {
    "type": "git",
    "url": "https://github.com/AndreaBonn/deadline-aura.git"
  },
  "homepage": "https://github.com/AndreaBonn/deadline-aura#readme",
  "bugs": {
    "url": "https://github.com/AndreaBonn/deadline-aura/issues"
  },
  "dependencies": {
    "better-sqlite3": "^11.10.0",
    "canvas": "^3.2.3",
    "dotenv": "^17.4.2",
    "googleapis": "^144.0.0",
    "zod": "^3.23.0"
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css,html}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.2",
    "@vitest/coverage-v8": "^2.0.0",
    "electron": "^36.9.5",
    "electron-builder": "^26.0.0",
    "eslint": "^9.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.3.0",
    "vitest": "^2.0.0"
  },
  "build": {
    "appId": "io.github.AndreaBonn.DeadlineAura",
    "productName": "DeadlineAura",
    "copyright": "Copyright © 2026 Andrea Bonn",
    "asar": true,
    "asarUnpack": [
      "node_modules/better-sqlite3/**",
      "node_modules/canvas/**",
      "assets/backgrounds/**"
    ],
    "files": [
      "main.js",
      "preload*.js",
      "ai/**",
      "config/**",
      "core/**",
      "i18n/**",
      "integrations/**",
      "renderer/**",
      "store/**",
      "assets/**",
      "!**/*.test.js",
      "!**/__tests__/**"
    ],
    "extraResources": [
      {
        "from": "build/autostart/deadlineaura.desktop",
        "to": "autostart/deadlineaura.desktop"
      },
      {
        "from": ".env.example",
        "to": ".env.example"
      }
    ],
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "linux": {
      "target": [
        "deb"
      ],
      "category": "Utility",
      "icon": "build/icons",
      "synopsis": "Deadline-aware ambient desktop widget",
      "description": "DeadlineAura turns upcoming deadlines into ambient visual pressure on your desktop: a sidebar, dynamic wallpaper and meeting dock driven by your calendar, Jira and optional AI scoring.",
      "desktop": {
        "entry": {
          "StartupWMClass": "deadlineaura"
        }
      }
    },
    "deb": {
      "maintainer": "Andrea Bonn <andreabonacci95@protonmail.com>",
      "afterInstall": "build/deb-after-install.sh",
      "afterRemove": "build/deb-after-remove.sh",
      "depends": [
        "libgtk-3-0",
        "libnotify4",
        "libnss3",
        "libxss1",
        "libxtst6",
        "xdg-utils",
        "libatspi2.0-0",
        "libdrm2",
        "libgbm1",
        "libasound2t64 | libasound2",
        "libcairo2",
        "libpango-1.0-0",
        "libpangocairo-1.0-0",
        "libjpeg-turbo8 | libjpeg8",
        "libgif7",
        "librsvg2-2"
      ]
    }
  }
}
